# =============================================================================
# Fraud Detection System — Environment Configuration
# Copy this file to .env and adjust values before running
# NEVER commit .env with real credentials to version control
# =============================================================================

# -----------------------------------------------------------------------------
# CORE LAYER
# -----------------------------------------------------------------------------

# Redpanda / Kafka
REDPANDA_KAFKA_PORT=9092
REDPANDA_ADMIN_PORT=9644
REDPANDA_SCHEMA_PORT=8081
REDPANDA_PROXY_PORT=8082
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis (Feast Online Feature Store)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# PostgreSQL (Transactions + Audit + MLflow backend + Airflow backend)
POSTGRES_PORT=5432
POSTGRES_USER=fraud_admin
POSTGRES_PASSWORD=fraud_secret_2024
POSTGRES_DB=fraud_db
POSTGRES_URL=postgresql://fraud_admin:fraud_secret_2024@localhost:5432/fraud_db

# -----------------------------------------------------------------------------
# DATA LAYER
# -----------------------------------------------------------------------------

# ClickHouse (Analytics OLAP)
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=fraud_admin
CLICKHOUSE_PASSWORD=fraud_secret_2024
CLICKHOUSE_DB=fraud_analytics
CLICKHOUSE_URL=http://localhost:8123

# MinIO (Feast Offline Feature Store + MLflow Artifacts)
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002
MINIO_ROOT_USER=fraud_minio
MINIO_ROOT_PASSWORD=fraud_minio_2024
MINIO_ENDPOINT=http://localhost:9001
# Buckets auto-created on init:
# - feast-offline   (historical features / point-in-time joins)
# - mlflow-artifacts (model artifacts, experiment outputs)
# - fraud-data      (raw data lake, synthetic datasets)
# - feature-snapshots (daily feature snapshots for monitoring)

# Neo4j (Graph Intelligence — Entity Linkage)
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraud_neo4j_2024
NEO4J_URI=bolt://localhost:7687

# -----------------------------------------------------------------------------
# COMPUTE LAYER
# -----------------------------------------------------------------------------

# Apache Flink
FLINK_UI_PORT=8083
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=6123

# MLflow (Model Registry + Experiment Tracking)
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud_detection_v1

# -----------------------------------------------------------------------------
# ORCHESTRATION LAYER
# -----------------------------------------------------------------------------

# Apache Airflow
AIRFLOW_PORT=8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=fraud_admin_2024
# IMPORTANT: Generate a real fernet key in production:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=bVz2Jt7oFr1Ky4pqDuEwX9nMsAhLcBgR6iNZW0Qv3Ue8kPj5TdH
AIRFLOW_SECRET_KEY=fraud_airflow_secret_2024

# -----------------------------------------------------------------------------
# MONITORING LAYER
# -----------------------------------------------------------------------------

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=fraud_grafana_2024

# -----------------------------------------------------------------------------
# APPLICATION MICROSERVICES (Phases 3–5, added later)
# -----------------------------------------------------------------------------

# Stage 1: Fast Risk Service (FastAPI)
STAGE1_PORT=8100
STAGE1_MODEL_PATH=/models/stage1/lgbm_model.pkl
STAGE1_THRESHOLD_LOW=0.1
STAGE1_THRESHOLD_HIGH=0.7

# Stage 2: Deep Intelligence Service (FastAPI)
STAGE2_PORT=8200

# Stage 3: Decision Engine (FastAPI)
STAGE3_PORT=8300

# Action Engine (FastAPI)
ACTION_ENGINE_PORT=8400

# API Gateway (FastAPI)
GATEWAY_PORT=8000

# -----------------------------------------------------------------------------
# SYSTEM TUNING (32GB RAM machine)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=fraud_detection
COMPOSE_HTTP_TIMEOUT=120
DOCKER_BUILDKIT=1
